#!/usr/bin/env python3
"""
claude-recover-scan: Shared session scanner for recover-sessions and cmux-recover-sessions.

Usage:
  claude-recover-scan <days_ago> <from_date> <to_date>

Output:
  Pipe-delimited lines: mod_time|size|session_id|cwd|first_msg|home_label
"""
import json, os, sys, datetime

days_ago_str = sys.argv[1]
from_date_str = sys.argv[2]
to_date_str = sys.argv[3]

def parse_date(s):
    if not s:
        return None
    if len(s) <= 5:
        s = f"{datetime.datetime.now().year}-{s}"
    return datetime.datetime.strptime(s, "%Y-%m-%d")

if from_date_str:
    cutoff = parse_date(from_date_str)
    if to_date_str:
        cutoff_end = parse_date(to_date_str) + datetime.timedelta(days=1)
    else:
        cutoff_end = datetime.datetime.now().replace(hour=0, minute=0, second=0)
else:
    cutoff = datetime.datetime.now() - datetime.timedelta(days=int(days_ago_str))
    cutoff_end = None

# Discover all Claude config homes (~/.claude, ~/.claude-5x, etc.)
# Deduplicate by realpath to avoid scanning symlinked projects/ twice
import glob
home_dir = os.path.expanduser("~")
config_homes = {}  # base_path -> label
seen_realpaths = set()
all_labels = []  # track all config homes for display
# Sort: non-symlinks first so canonical paths win dedup
candidates = sorted(glob.glob(os.path.join(home_dir, ".claude*/projects")),
                    key=lambda p: (os.path.islink(p), len(p)))
for d in candidates:
    config_dir = os.path.basename(os.path.dirname(d))  # ".claude" or ".claude-5x"
    if config_dir == ".claude":
        label = "claude"
    else:
        label = config_dir.replace(".claude-", "")  # "5x"
    all_labels.append(label)
    real = os.path.realpath(d)
    if real in seen_realpaths:
        continue  # symlink to already-scanned directory
    seen_realpaths.add(real)
    config_homes[d] = label

SCHEDULE_PREFIXES = [
    "You are an SLA",
    "Collect today",
    "Scan local repos",
    "Create a weekly planning seed",
    "Create a morning briefing",
    "Run an end-of-day",
    "Collect unanswered PR review",
]

SCHEDULE_KEYWORDS = [
    "stale branches and worktrees",
    "SLA deep analysis agent",
]

MIN_USER_MSGS = 4
TAIL_SIZE = 15
USER_TAIL_SIZE = 20

results = []

for base, home_label in config_homes.items():
    if not os.path.isdir(base):
        continue
    for project_dir_name in os.listdir(base):
        full_dir = os.path.join(base, project_dir_name)
        if not os.path.isdir(full_dir):
            continue
        for fname in os.listdir(full_dir):
            if not fname.endswith(".jsonl"):
                continue
            fpath = os.path.join(full_dir, fname)

            if "/subagents/" in fpath:
                continue

            mtime = datetime.datetime.fromtimestamp(os.path.getmtime(fpath))
            if mtime < cutoff:
                continue
            if cutoff_end and mtime >= cutoff_end:
                continue

            size = os.path.getsize(fpath)
            if size < 10240:
                continue

            size_h = f"{size/1048576:.1f}M" if size > 1048576 else f"{size//1024}K"
            mod_time = mtime.strftime("%m/%d %H:%M")

            session_id = fname[:-6]
            cwd = ""
            user_count = 0
            first_real_msg = ""
            is_teammate = False
            is_command = False
            is_schedule = False
            tail_buf = []
            user_tail_buf = []
            was_exited = False

            with open(fpath) as f:
                for line in f:
                    try:
                        obj = json.loads(line.strip())

                        tail_buf.append(obj)
                        if len(tail_buf) > TAIL_SIZE:
                            tail_buf.pop(0)

                        if not cwd and obj.get("cwd"):
                            cwd = obj["cwd"]

                        if obj.get("type") == "user" and not obj.get("isSidechain"):
                            user_count += 1
                            user_tail_buf.append(obj)
                            if len(user_tail_buf) > USER_TAIL_SIZE:
                                user_tail_buf.pop(0)
                            msg = obj.get("message", {})
                            raw = msg.get("content", "") if isinstance(msg, dict) else str(msg)
                            if not isinstance(raw, str):
                                continue
                            c = raw.strip()

                            if user_count <= 5:
                                if c.startswith("<teammate-message"):
                                    is_teammate = True
                                if "oh-my-claudecode:team" in c or "omc-teams" in c:
                                    is_command = True
                                    is_teammate = True
                                if user_count == 1:
                                    if c.startswith("<command-name>") or c.startswith("<command-message>"):
                                        is_command = True

                            if not first_real_msg:
                                if not (c.startswith("<") or len(c) <= 5):
                                    first_real_msg = c.replace("\n", " ")[:80]

                    except Exception:
                        pass

            # Detect intentional exit by inspecting ONLY the most recent real
            # user turn. Earlier /exit hits in the tail (e.g. a session that
            # was resumed after an explicit exit) must not bubble up, or we
            # risk dropping live sessions whose tail still carries the stale
            # /exit command. Wrappers like <local-command-stdout> and
            # <local-command-caveat> are skipped because Claude Code emits
            # those as additional user-type events after executing /exit.
            for obj in reversed(user_tail_buf):
                msg = obj.get("message", {})
                raw = msg.get("content", "") if isinstance(msg, dict) else str(msg)
                if not isinstance(raw, str):
                    continue
                c = raw.strip()
                if c.startswith("<local-command-stdout>") or c.startswith("<local-command-caveat>"):
                    continue
                # First real user turn we hit (scanning from newest back).
                # Require the explicit <command-name>/exit</command-name>
                # token so that a literal "/exit" in chat prose does not
                # trigger the filter.
                if ("<command-name>/exit</command-name>" in c
                        or "<command-name>/quit</command-name>" in c):
                    was_exited = True
                break

            # ── Filtering ──
            if is_teammate:
                continue
            if is_command and user_count <= 5:
                continue
            if user_count < MIN_USER_MSGS:
                continue

            if first_real_msg:
                for prefix in SCHEDULE_PREFIXES:
                    if first_real_msg.startswith(prefix):
                        is_schedule = True
                        break
                if not is_schedule:
                    for kw in SCHEDULE_KEYWORDS:
                        if kw in first_real_msg:
                            is_schedule = True
                            break
            if is_schedule:
                continue
            if was_exited:
                continue
            if not first_real_msg:
                continue

            cwd = cwd or "/tmp"
            results.append((mod_time, size_h, session_id, cwd, first_real_msg, home_label))

results.sort(key=lambda x: x[0], reverse=True)

for mod_time, size_h, sid, cwd, msg, hlabel in results:
    print(f"{mod_time}|{size_h}|{sid}|{cwd}|{msg}|{hlabel}")
