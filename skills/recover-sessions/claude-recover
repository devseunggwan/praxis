#!/bin/bash
# claude-recover: Bulk recover Claude Code sessions into tmux panes
#
# Workflow:
#   1. Scan recent sessions and create tmux sessions with grid layout
#   2. Attach via Ghostty tabs (one tab per tmux session)
#
# Usage:
#   claude-recover                                # Last 1 day (default)
#   claude-recover --days 3                       # Last 3 days
#   claude-recover --from 03-18 --to 03-20        # Date range
#   claude-recover --list                         # List only (no tmux creation)
#   claude-recover --attach                       # Create + auto-attach to first
#   claude-recover --windows                      # Open all in Ghostty tabs (macOS)

set -euo pipefail

DAYS_AGO=""
FROM_DATE=""
TO_DATE=""
LAYOUT="1x2"  # CxR: columns x rows per tmux session
MODE="create"  # create | list | attach | windows

while [[ $# -gt 0 ]]; do
  case "$1" in
    --days)    DAYS_AGO="$2"; shift 2 ;;
    --from)    FROM_DATE="$2"; shift 2 ;;
    --to)      TO_DATE="$2"; shift 2 ;;
    --layout)  LAYOUT="$2"; shift 2 ;;
    --list)    MODE="list"; shift ;;
    --attach)  MODE="attach"; shift ;;
    --windows) MODE="windows"; shift ;;
    -h|--help)
      cat << 'HELP'
Usage: claude-recover [--days N | --from DATE --to DATE] [--layout CxR] [--list|--attach|--windows]

Options:
  --days N        Scan last N days (default: 1)
  --from DATE     Start date (YYYY-MM-DD or MM-DD)
  --to DATE       End date (YYYY-MM-DD or MM-DD, default: yesterday)
  --layout CxR    tmux pane grid layout (cols x rows, default: 1x2)
  --list          List recovery targets only (no tmux creation)
  --attach        Create tmux sessions + auto-attach to first
  --windows       Open all sessions in Ghostty tabs (macOS)

Examples:
  claude-recover --list --days 3                    # Last 3 days
  claude-recover --list --from 03-18 --to 03-20    # Mar 18-20
  claude-recover --from 03-20 --layout 3x2         # 3/20~yesterday, 6 panes/tab
  claude-recover --from 03-20 --layout 2x2         # 3/20~yesterday, 4 panes/tab

Layout examples:
  1x2  = 2 panes (top/bottom, default)
  2x1  = 2 panes (left/right)
  2x2  = 4 panes (2x2 grid)
  3x2  = 6 panes (3 cols, 2 rows)

After recovery, in each Ghostty tab:
  tmux attach -t cr-1
  tmux attach -t cr-2
  ...
HELP
      exit 0
      ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

# Default: --days 1 if no date range specified
if [[ -z "$DAYS_AGO" && -z "$FROM_DATE" ]]; then
  DAYS_AGO=1
fi

# ── Phase 1: Scan sessions (Python) ──

SCAN_OUTPUT=$(python3 - "${DAYS_AGO:-}" "${FROM_DATE:-}" "${TO_DATE:-}" << 'PYSCAN'
import json, os, sys, datetime

days_ago_str = sys.argv[1]
from_date_str = sys.argv[2]
to_date_str = sys.argv[3]

def parse_date(s):
    if not s:
        return None
    if len(s) <= 5:
        s = f"{datetime.datetime.now().year}-{s}"
    return datetime.datetime.strptime(s, "%Y-%m-%d")

if from_date_str:
    cutoff = parse_date(from_date_str)
    if to_date_str:
        cutoff_end = parse_date(to_date_str) + datetime.timedelta(days=1)
    else:
        cutoff_end = datetime.datetime.now().replace(hour=0, minute=0, second=0)
else:
    cutoff = datetime.datetime.now() - datetime.timedelta(days=int(days_ago_str))
    cutoff_end = None

# Discover all Claude config homes (~/.claude, ~/.claude-5x, etc.)
# Deduplicate by realpath to avoid scanning symlinked projects/ twice
import glob
home_dir = os.path.expanduser("~")
config_homes = {}  # base_path -> label
seen_realpaths = set()
all_labels = []  # track all config homes for display
# Sort: non-symlinks first so canonical paths win dedup
candidates = sorted(glob.glob(os.path.join(home_dir, ".claude*/projects")),
                    key=lambda p: (os.path.islink(p), len(p)))
for d in candidates:
    config_dir = os.path.basename(os.path.dirname(d))  # ".claude" or ".claude-5x"
    if config_dir == ".claude":
        label = "claude"
    else:
        label = config_dir.replace(".claude-", "")  # "5x"
    all_labels.append(label)
    real = os.path.realpath(d)
    if real in seen_realpaths:
        continue  # symlink to already-scanned directory
    seen_realpaths.add(real)
    config_homes[d] = label

SCHEDULE_PREFIXES = [
    "You are an SLA",
    "Collect today",
    "Scan local repos",
    "Create a weekly planning seed",
    "Create a morning briefing",
    "Run an end-of-day",
    "Collect unanswered PR review",
]

SCHEDULE_KEYWORDS = [
    "stale branches and worktrees",
    "SLA deep analysis agent",
]

MIN_USER_MSGS = 4
TAIL_SIZE = 15

results = []

for base, home_label in config_homes.items():
    if not os.path.isdir(base):
        continue
    for project_dir_name in os.listdir(base):
        full_dir = os.path.join(base, project_dir_name)
        if not os.path.isdir(full_dir):
            continue
        for fname in os.listdir(full_dir):
            if not fname.endswith(".jsonl"):
                continue
            fpath = os.path.join(full_dir, fname)

            if "/subagents/" in fpath:
                continue

            mtime = datetime.datetime.fromtimestamp(os.path.getmtime(fpath))
            if mtime < cutoff:
                continue
            if cutoff_end and mtime >= cutoff_end:
                continue

            size = os.path.getsize(fpath)
            if size < 10240:
                continue

            size_h = f"{size/1048576:.1f}M" if size > 1048576 else f"{size//1024}K"
            mod_time = mtime.strftime("%m/%d %H:%M")

            session_id = fname[:-6]
            cwd = ""
            user_count = 0
            first_real_msg = ""
            is_teammate = False
            is_command = False
            is_schedule = False
            tail_buf = []
            was_exited = False

            with open(fpath) as f:
                for line in f:
                    try:
                        obj = json.loads(line.strip())

                        tail_buf.append(obj)
                        if len(tail_buf) > TAIL_SIZE:
                            tail_buf.pop(0)

                        if not cwd and obj.get("cwd"):
                            cwd = obj["cwd"]

                        if obj.get("type") == "user" and not obj.get("isSidechain"):
                            user_count += 1
                            msg = obj.get("message", {})
                            raw = msg.get("content", "") if isinstance(msg, dict) else str(msg)
                            if not isinstance(raw, str):
                                continue
                            c = raw.strip()

                            if user_count <= 5:
                                if c.startswith("<teammate-message"):
                                    is_teammate = True
                                if "oh-my-claudecode:team" in c or "omc-teams" in c:
                                    is_command = True
                                    is_teammate = True
                                if user_count == 1:
                                    if c.startswith("<command-name>") or c.startswith("<command-message>"):
                                        is_command = True

                            if not first_real_msg:
                                if not (c.startswith("<") or len(c) <= 5):
                                    first_real_msg = c.replace("\n", " ")[:80]

                    except Exception:
                        pass

            # Detect intentional exit in tail
            # Check for /exit command or known goodbye messages
            for obj in tail_buf:
                if obj.get("type") == "user":
                    msg = obj.get("message", {})
                    raw = msg.get("content", "") if isinstance(msg, dict) else str(msg)
                    if isinstance(raw, str):
                        if "/exit" in raw or "/quit" in raw:
                            was_exited = True
                            break

            # ── Filtering ──
            if is_teammate:
                continue
            if is_command and user_count <= 5:
                continue
            if user_count < MIN_USER_MSGS:
                continue

            if first_real_msg:
                for prefix in SCHEDULE_PREFIXES:
                    if first_real_msg.startswith(prefix):
                        is_schedule = True
                        break
                if not is_schedule:
                    for kw in SCHEDULE_KEYWORDS:
                        if kw in first_real_msg:
                            is_schedule = True
                            break
            if is_schedule:
                continue
            if was_exited:
                continue
            if not first_real_msg:
                continue

            cwd = cwd or "/tmp"
            results.append((mod_time, size_h, session_id, cwd, first_real_msg, home_label))

results.sort(key=lambda x: x[0], reverse=True)

for mod_time, size_h, sid, cwd, msg, hlabel in results:
    print(f"{mod_time}|{size_h}|{sid}|{cwd}|{msg}|{hlabel}")
PYSCAN
)

declare -a SESSIONS=()
while IFS='|' read -r mod_time size session_id project_dir first_msg home_label; do
  [[ -z "$mod_time" ]] && continue
  SESSIONS+=("${mod_time}|${size}|${session_id}|${project_dir}|${first_msg}|${home_label}")
done <<< "$SCAN_OUTPUT"

if [[ ${#SESSIONS[@]} -eq 0 ]]; then
  echo "No sessions to recover."
  if [[ -n "$FROM_DATE" ]]; then
    echo "Range: ${FROM_DATE} ~ ${TO_DATE:-yesterday}"
  else
    echo "Range: last ${DAYS_AGO} day(s)"
  fi
  echo "Try wider range: claude-recover --days 3"
  exit 0
fi

# ── Phase 2: Display session list ──

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║  Claude Code Session Recovery — ${#SESSIONS[@]} sessions found"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

printf "%-4s %-12s %-5s %-8s %-34s %s\n" "#" "TIME" "SIZE" "HOME" "PROJECT" "FIRST MESSAGE"
printf "%-4s %-12s %-5s %-8s %-34s %s\n" "---" "----------" "----" "------" "-------" "-------------"

for i in "${!SESSIONS[@]}"; do
  IFS='|' read -r mod_time size session_id project_dir first_msg home_label <<< "${SESSIONS[$i]}"
  idx=$((i + 1))
  short_project=$(echo "$project_dir" | sed "s|$HOME/projects/||; s|$HOME/||" | cut -c1-32)
  short_msg=$(echo "$first_msg" | cut -c1-45)
  printf "%-4s %-12s %-5s %-8s %-34s %s\n" "$idx" "$mod_time" "$size" "$home_label" "$short_project" "$short_msg"
done

echo ""

[[ "$MODE" == "list" ]] && exit 0

# ── Phase 3: Create single tmux session with multiple windows ──

# Parse layout: CxR
COLS=${LAYOUT%%x*}
ROWS=${LAYOUT##*x}
PANES_PER_WIN=$((COLS * ROWS))
TMUX_SESSION="cr"

echo "Creating tmux session '${TMUX_SESSION}'... (layout: ${COLS}x${ROWS} = ${PANES_PER_WIN} panes/window)"

# Check for existing recovery session — never kill active sessions
if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
  ATTACHED=$(tmux list-clients -t "$TMUX_SESSION" 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$ATTACHED" -gt 0 ]]; then
    echo "⚠️  Session '${TMUX_SESSION}' exists and has ${ATTACHED} attached client(s)."
    echo "   Cannot overwrite an active session."
    echo ""
    echo "Options:"
    echo "  1. Detach/close the existing session first"
    echo "  2. Kill it manually: tmux kill-session -t ${TMUX_SESSION}"
    exit 1
  else
    echo "Removing detached session '${TMUX_SESSION}'..."
    tmux kill-session -t "$TMUX_SESSION" 2>/dev/null || true
  fi
fi

# Helper: build resume command based on config home
build_resume_cmd() {
  local sid="$1" home="$2"
  if [[ "$home" == "claude" ]]; then
    echo "claude --resume ${sid}"
  else
    # Use CLAUDE_CONFIG_DIR for non-default config homes (portable)
    echo "CLAUDE_CONFIG_DIR=\$HOME/.claude-${home} claude --resume ${sid}"
  fi
}

win_num=0
i=0

while [[ $i -lt ${#SESSIONS[@]} ]]; do
  IFS='|' read -r _ _ sid1 dir1 _ home1 <<< "${SESSIONS[$i]}"
  resume_cmd1=$(build_resume_cmd "$sid1" "$home1")

  if [[ $win_num -eq 0 ]]; then
    # First window: create the session
    tmux new-session -d -s "$TMUX_SESSION" -c "$dir1"
    tmux send-keys -t "${TMUX_SESSION}:${win_num}.0" "$resume_cmd1" Enter
  else
    # Additional windows within the same session
    tmux new-window -t "$TMUX_SESSION" -c "$dir1"
    tmux send-keys -t "${TMUX_SESSION}:${win_num}.0" "$resume_cmd1" Enter
  fi
  i=$((i + 1))

  # Create remaining panes for this window
  pane_idx=1
  while [[ $pane_idx -lt $PANES_PER_WIN && $i -lt ${#SESSIONS[@]} ]]; do
    IFS='|' read -r _ _ sid dir _ home_lbl <<< "${SESSIONS[$i]}"
    resume_cmd=$(build_resume_cmd "$sid" "$home_lbl")

    row=$((pane_idx / COLS))
    col=$((pane_idx % COLS))

    if [[ $col -eq 0 ]]; then
      prev_row_pane=$(( (row - 1) * COLS ))
      tmux split-window -v -t "${TMUX_SESSION}:${win_num}.${prev_row_pane}" -c "$dir"
    else
      tmux split-window -h -t "${TMUX_SESSION}:${win_num}.$((pane_idx - 1))" -c "$dir"
    fi

    tmux send-keys -t "${TMUX_SESSION}:${win_num}.${pane_idx}" "$resume_cmd" Enter
    pane_idx=$((pane_idx + 1))
    i=$((i + 1))
  done

  # Apply correct layout based on grid dimensions
  if [[ $COLS -eq 1 ]]; then
    tmux select-layout -t "${TMUX_SESSION}:${win_num}" even-vertical 2>/dev/null || true
  elif [[ $ROWS -eq 1 ]]; then
    tmux select-layout -t "${TMUX_SESSION}:${win_num}" even-horizontal 2>/dev/null || true
  else
    tmux select-layout -t "${TMUX_SESSION}:${win_num}" tiled 2>/dev/null || true
  fi

  echo "  ✓ window ${win_num} created (${pane_idx} panes)"
  win_num=$((win_num + 1))
done

# Select first window
tmux select-window -t "${TMUX_SESSION}:0"

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo " Session '${TMUX_SESSION}' created with ${win_num} windows"
echo "═══════════════════════════════════════════════════════════════"
echo ""

# ── Phase 4: Attach or show instructions ──

if [[ "$MODE" == "windows" ]]; then
  # Detect terminal app and open accordingly
  TERM_APP=""
  if [[ "$TERM_PROGRAM" == "ghostty" ]] || pgrep -q Ghostty 2>/dev/null; then
    TERM_APP="Ghostty"
  elif [[ "$TERM_PROGRAM" == "iTerm.app" ]] || pgrep -q iTerm2 2>/dev/null; then
    TERM_APP="iTerm"
  elif [[ "$TERM_PROGRAM" == "Apple_Terminal" ]]; then
    TERM_APP="Terminal"
  fi

  case "$TERM_APP" in
    Ghostty)
      echo "Opening Ghostty window..."
      open -na Ghostty.app --args -e tmux attach -t "$TMUX_SESSION"
      ;;
    iTerm)
      echo "Opening iTerm2 window..."
      open -na iTerm.app --args -e tmux attach -t "$TMUX_SESSION"
      ;;
    Terminal)
      echo "Opening Terminal window..."
      open -na Terminal.app --args -e tmux attach -t "$TMUX_SESSION"
      ;;
    *)
      echo "⚠️  Could not detect terminal app. Attach manually:"
      echo "  tmux a -t ${TMUX_SESSION}"
      ;;
  esac

  sleep 1
  if [[ -n "$TERM_APP" ]]; then
    echo "✅ ${TERM_APP} window opened with ${win_num} tmux windows"
  fi
  echo ""
  echo "Navigate: Ctrl+B n (next) / Ctrl+B p (prev) / Ctrl+B 0-$((win_num-1)) (by number)"

elif [[ "$MODE" == "attach" ]]; then
  echo "Attaching to session '${TMUX_SESSION}' (${win_num} windows)..."
  echo "Navigate: Ctrl+B n (next) / Ctrl+B p (prev) / Ctrl+B 0-$((win_num-1)) (by number)"
  echo ""
  exec tmux attach -t "$TMUX_SESSION"

else
  echo "Attach to the recovery session:"
  echo ""
  echo "  tmux a -t ${TMUX_SESSION}"
  echo ""
  echo "Navigate between windows:"
  echo "  Ctrl+B n     next window"
  echo "  Ctrl+B p     previous window"
  echo "  Ctrl+B 0-$((win_num-1))   jump to window by number"
  echo ""
  echo "Or open in new terminal window: claude-recover --windows"
  echo "Or auto-attach: claude-recover --attach"
fi
