#!/bin/bash
# cmux-recover-sessions: Bulk recover Claude Code sessions into cmux workspaces
#
# Workflow:
#   1. Scan recent sessions (shared logic with claude-recover)
#   2. Create cmux workspaces (tabs or splits)
#
# Usage:
#   cmux-recover-sessions                                # Last 1 day, tabs mode
#   cmux-recover-sessions --days 3                       # Last 3 days
#   cmux-recover-sessions --from 03-18 --to 03-20        # Date range
#   cmux-recover-sessions --list                         # List only
#   cmux-recover-sessions --split 1x2                    # 2 sessions per workspace
#   cmux-recover-sessions --rename                       # Auto-rename workspaces

set -euo pipefail

DAYS_AGO=""
FROM_DATE=""
TO_DATE=""
MODE="tabs"       # tabs | list | split
SPLIT_LAYOUT=""   # CxR for split mode
RENAME=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --days)    DAYS_AGO="$2"; shift 2 ;;
    --from)    FROM_DATE="$2"; shift 2 ;;
    --to)      TO_DATE="$2"; shift 2 ;;
    --tabs)    MODE="tabs"; shift ;;
    --split)   MODE="split"; SPLIT_LAYOUT="$2"; shift 2 ;;
    --list)    MODE="list"; shift ;;
    --rename)  RENAME=true; shift ;;
    -h|--help)
      cat << 'HELP'
Usage: cmux-recover-sessions [--days N | --from DATE --to DATE] [--tabs|--split CxR] [--list] [--rename]

Options:
  --days N        Scan last N days (default: 1)
  --from DATE     Start date (YYYY-MM-DD or MM-DD)
  --to DATE       End date (YYYY-MM-DD or MM-DD, default: yesterday)
  --tabs          1 session per workspace tab (default)
  --split CxR     CxR grid per workspace (e.g., 1x2, 2x2)
  --list          List recovery targets only
  --rename        Auto-rename workspaces with session info

Examples:
  cmux-recover-sessions --list --days 3
  cmux-recover-sessions --from 03-23 --to 03-25
  cmux-recover-sessions --from 03-25 --split 1x2
  cmux-recover-sessions --from 03-25 --tabs --rename
HELP
      exit 0
      ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

# Default: --days 1 if no date range specified
if [[ -z "$DAYS_AGO" && -z "$FROM_DATE" ]]; then
  DAYS_AGO=1
fi

# ── Pre-flight: verify cmux is reachable ──

if [[ "$MODE" != "list" ]]; then
  if ! cmux ping >/dev/null 2>&1; then
    echo "❌ cmux is not reachable. Start cmux app first."
    echo "   Run: open -a cmux"
    exit 1
  fi
fi

# ── Phase 1: Scan sessions (Python — shared logic with claude-recover) ──

# ── Phase 1: Scan sessions (shared module) ──

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCAN_SCRIPT="${SCRIPT_DIR}/../recover-sessions/claude-recover-scan"
SCAN_OUTPUT=$(python3 "${SCAN_SCRIPT}" "${DAYS_AGO:-}" "${FROM_DATE:-}" "${TO_DATE:-}")

declare -a SESSIONS=()
while IFS='|' read -r mod_time size session_id project_dir first_msg home_label; do
  [[ -z "$mod_time" ]] && continue
  SESSIONS+=("${mod_time}|${size}|${session_id}|${project_dir}|${first_msg}|${home_label}")
done <<< "$SCAN_OUTPUT"

if [[ ${#SESSIONS[@]} -eq 0 ]]; then
  echo "No sessions to recover."
  if [[ -n "$FROM_DATE" ]]; then
    echo "Range: ${FROM_DATE} ~ ${TO_DATE:-yesterday}"
  else
    echo "Range: last ${DAYS_AGO} day(s)"
  fi
  echo "Try wider range: cmux-recover-sessions --days 3"
  exit 0
fi

# ── Phase 2: Display session list ──

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║  Claude Code Session Recovery (cmux) — ${#SESSIONS[@]} sessions found"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

printf "%-4s %-12s %-5s %-8s %-34s %s\n" "#" "TIME" "SIZE" "HOME" "PROJECT" "FIRST MESSAGE"
printf "%-4s %-12s %-5s %-8s %-34s %s\n" "---" "----------" "----" "------" "-------" "-------------"

for i in "${!SESSIONS[@]}"; do
  IFS='|' read -r mod_time size session_id project_dir first_msg home_label <<< "${SESSIONS[$i]}"
  idx=$((i + 1))
  short_project=$(echo "$project_dir" | sed "s|$HOME/projects/||; s|$HOME/||" | cut -c1-32)
  short_msg=$(echo "$first_msg" | cut -c1-45)
  printf "%-4s %-12s %-5s %-8s %-34s %s\n" "$idx" "$mod_time" "$size" "$home_label" "$short_project" "$short_msg"
done

echo ""

[[ "$MODE" == "list" ]] && exit 0

# ── Phase 3: Create cmux workspaces ──

# Helper: build resume command based on config home
build_resume_cmd() {
  local sid="$1" home="$2"
  if [[ "$home" == "claude" ]]; then
    echo "claude --resume ${sid}"
  else
    echo "CLAUDE_CONFIG_DIR=\$HOME/.claude-${home} claude --resume ${sid}"
  fi
}

# Helper: extract ref from cmux output ("OK workspace:48" → "workspace:48")
parse_cmux_ref() {
  echo "$1" | sed 's/^OK //'
}

if [[ "$MODE" == "tabs" ]]; then
  # ── Tabs mode: 1 workspace per session ──

  echo "Creating cmux workspaces (1 per session)..."
  echo ""

  created=0
  for i in "${!SESSIONS[@]}"; do
    IFS='|' read -r mod_time size session_id project_dir first_msg home_label <<< "${SESSIONS[$i]}"
    resume_cmd=$(build_resume_cmd "$session_id" "$home_label")

    raw_out=$(cmux new-workspace --cwd "$project_dir" --command "$resume_cmd" 2>/dev/null)
    ws_ref=$(parse_cmux_ref "$raw_out")
    if [[ $? -eq 0 && -n "$ws_ref" ]]; then
      if [[ "$RENAME" == true ]]; then
        short_name=$(echo "$first_msg" | cut -c1-30)
        cmux rename-workspace --workspace "$ws_ref" "$short_name" 2>/dev/null || true
      fi
      created=$((created + 1))
      echo "  ✓ workspace $((i + 1)): ${first_msg:0:50}"
    else
      echo "  ✗ workspace $((i + 1)): failed to create"
    fi
  done

  echo ""
  echo "═══════════════════════════════════════════════════════════════"
  echo " ${created} workspaces created in cmux"
  echo "═══════════════════════════════════════════════════════════════"

elif [[ "$MODE" == "split" ]]; then
  # ── Split mode: N sessions per workspace ──

  COLS=${SPLIT_LAYOUT%%x*}
  ROWS=${SPLIT_LAYOUT##*x}
  PANES_PER_WS=$((COLS * ROWS))

  echo "Creating cmux workspaces (${COLS}x${ROWS} = ${PANES_PER_WS} sessions/workspace)..."
  echo ""

  ws_num=0
  i=0

  while [[ $i -lt ${#SESSIONS[@]} ]]; do
    # First session in workspace: create workspace
    IFS='|' read -r _ _ sid1 dir1 msg1 home1 <<< "${SESSIONS[$i]}"
    resume_cmd1=$(build_resume_cmd "$sid1" "$home1")

    raw_out=$(cmux new-workspace --cwd "$dir1" --command "$resume_cmd1" 2>/dev/null)
    ws_ref=$(parse_cmux_ref "$raw_out")
    if [[ -z "$ws_ref" ]]; then
      echo "  ✗ workspace ${ws_num}: failed to create"
      i=$((i + 1))
      continue
    fi

    if [[ "$RENAME" == true ]]; then
      cmux rename-workspace --workspace "$ws_ref" "recover-${ws_num}" 2>/dev/null || true
    fi

    i=$((i + 1))
    pane_idx=1

    # Create remaining panes via splits
    while [[ $pane_idx -lt $PANES_PER_WS && $i -lt ${#SESSIONS[@]} ]]; do
      IFS='|' read -r _ _ sid dir _ home_lbl <<< "${SESSIONS[$i]}"
      resume_cmd=$(build_resume_cmd "$sid" "$home_lbl")

      col=$((pane_idx % COLS))

      if [[ $col -eq 0 ]]; then
        # New row: split down
        cmux new-split down --workspace "$ws_ref" 2>/dev/null
      else
        # Same row: split right
        cmux new-split right --workspace "$ws_ref" 2>/dev/null
      fi

      # Send resume command to the newly created (focused) surface
      sleep 0.3
      cmux send --workspace "$ws_ref" "$resume_cmd" 2>/dev/null
      cmux send-key --workspace "$ws_ref" Enter 2>/dev/null

      pane_idx=$((pane_idx + 1))
      i=$((i + 1))
    done

    echo "  ✓ workspace ${ws_num} created (${pane_idx} panes)"
    ws_num=$((ws_num + 1))
  done

  echo ""
  echo "═══════════════════════════════════════════════════════════════"
  echo " ${ws_num} workspaces created in cmux (${SPLIT_LAYOUT} layout)"
  echo "═══════════════════════════════════════════════════════════════"
fi

echo ""
echo "Navigate workspaces:"
echo "  Cmd+1-9              jump by number"
echo "  Cmd+Shift+]          next workspace"
echo "  Cmd+Shift+[          previous workspace"
